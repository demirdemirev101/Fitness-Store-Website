@model Fitness_Store_Website.Models.AdminOrder.OrderViewModel
@{
    ViewBag.Title = "Order Details";
    Layout = "_AdminLayout";
}

<h2>Order #@Model.Id</h2>
<p><strong>User:</strong> @Model.UserId</p>
<p><strong>Date:</strong> @Model.CreatedOn.ToString("g")</p>
<p><strong>Total:</strong> @Model.Total.ToString("0.00") €</p>
<p><strong>Payment:</strong> @Model.PaymentMethod (@Model.PaymentStatus)</p>

<h4>Items</h4>
<table class="table">
    <thead>
        <tr>
            <th>Product</th>
            <th>Unit Price</th>
            <th>Quantity</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model.Items)
        {
            <tr>
                <td>@i.ProductName</td>
                <td>@i.UnitPrice.ToString("0.00") €</td>
                <td>@i.Quantity</td>
                <td>@(i.UnitPrice * i.Quantity).ToString("0.00") €</td>
            </tr>
        }
    </tbody>
</table>
