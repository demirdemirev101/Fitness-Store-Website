@model List<Fitness_Store_Website.Models.AdminOrder.OrderViewModel>
@{
    ViewBag.Title = "Orders";
    Layout = "_AdminLayout";
}

<h2>Orders</h2>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>User</th>
            <th>Date</th>
            <th>Total</th>
            <th>Payment</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Id</td>
                <td>@o.UserId</td>
                <td>@o.CreatedOn.ToString("g")</td>
                <td>@o.Total.ToString("0.00") €</td>
                <td>@o.PaymentMethod</td>
                <td>@o.PaymentStatus</td>
                <td><a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-primary">Details</a></td>
            </tr>
        }
    </tbody>
</table>