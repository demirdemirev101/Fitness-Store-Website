@model AllProductsQueryModel

@{
    ViewBag.Title = "Всички продукти";
}

<h2 class="text-center mb-4">@ViewBag.Title</h2>

<div class="row">
    <aside class="col-md-3 mb-4">
        <div class="card p-3">
            <h5>Filters</h5>
            <form method="get" asp-action="All">
                <div class="mb-3">
                    <label class="form-label">Категории</label>
                    <select name="categoryId" class="form-select">
                        <option value="">Всички категории</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id" selected="@(Model.CategoryId == category.Id ? "selected" : null)">@category.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Сортиране</label>
                    <select name="sortOption" class="form-select">
                        <option value="">Без сортиране</option>
                        <option value="nameAsc" selected="@(Model.SortOption == "nameAsc" ? "selected" : null)">Име ↑</option>
                        <option value="nameDesc" selected="@(Model.SortOption == "nameDesc" ? "selected" : null)">Име ↓</option>
                        <option value="priceAsc" selected="@(Model.SortOption == "priceAsc" ? "selected" : null)">Цена ↑</option>
                        <option value="priceDesc" selected="@(Model.SortOption == "priceDesc" ? "selected" : null)">Цена ↓</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Цена (макс)</label>
                    <input type="number" name="maxPrice" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary w-100">Филтрирай</button>
            </form>
        </div>
    </aside>

    <section class="col-md-9">
        <div id="product-grid">
            @await Html.PartialAsync("_ProductGrid", Model)
        </div>

        @if (Model.TotalProductsCount > Model.ProductsPerPage)
        {
            var totalPages = (int)Math.Ceiling((double)Model.TotalProductsCount / Model.ProductsPerPage);

            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">

                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("All", new {
                                categoryId = Model.CategoryId,
                                sortOption = Model.SortOption,
                                currentPage = Model.CurrentPage - 1
                            })">Предишна</a>
                        </li>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("All", new {
                                categoryId = Model.CategoryId,
                                sortOption = Model.SortOption,
                                currentPage = i
                            })">@i</a>
                        </li>
                    }

                    @if (Model.CurrentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("All", new {
                                categoryId = Model.CategoryId,
                                sortOption = Model.SortOption,
                                currentPage = Model.CurrentPage + 1
                            })">Следваща</a>
                        </li>
                    }

                </ul>
            </nav>
        }
    </section>
</div>